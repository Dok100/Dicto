<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Developer ID: signiert für direkten Download außerhalb des App Store -->
    <key>method</key>
    <string>developer-id</string>

    <!-- Hardened Runtime ist Pflicht für die Notarisierung -->
    <key>hardcodedBuildSystemInfo</key>
    <false/>

    <key>signingStyle</key>
    <string>automatic</string>

    <!-- Entitlements: Mikrofon + Accessibility + Input Monitoring -->
    <key>entitlements</key>
    <dict>
        <key>com.apple.security.device.audio-input</key>
        <true/>
    </dict>
</dict>
</plist>
